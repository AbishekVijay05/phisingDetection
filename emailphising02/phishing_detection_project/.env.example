# Environment Configuration
# Copy this file to .env and fill in the values

# Kaggle credentials (needed for dataset download only)
# KAGGLE_USERNAME=your_username
# KAGGLE_KEY=your_api_key

# Model artifact paths (for FastAPI deployment)
NB_DIR=artifacts/nb
ROBERTA_DIR=artifacts/roberta

# API settings
# HOST=0.0.0.0
# PORT=8000
